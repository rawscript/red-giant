@PACKAGE_INIT@

# rgtp-config.cmake — CMake package config for downstream find_package(rgtp)
#
# Usage:
#   find_package(rgtp REQUIRED)
#   target_link_libraries(my_app PRIVATE rgtp::rgtp)
#
# Exported targets:
#   rgtp::rgtp   — default alias (static library)
#   rgtp::static — static library
#   rgtp::shared — shared library

include(CMakeFindDependencyMacro)

# Re-find crypto dependency so downstream targets link correctly
set(_rgtp_crypto_backend "@RGTP_CRYPTO_BACKEND@")
if(_rgtp_crypto_backend STREQUAL "libsodium")
    find_dependency(sodium)
elseif(_rgtp_crypto_backend STREQUAL "openssl")
    find_dependency(OpenSSL COMPONENTS Crypto)
endif()

# Include the exported targets
include("${CMAKE_CURRENT_LIST_DIR}/rgtpTargets.cmake")

check_required_components(rgtp)
